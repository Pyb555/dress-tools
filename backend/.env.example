# ==========================================
# AI 引擎选择: mock | fashn | ootd | dashscope
# ==========================================
TRYON_ENGINE=mock

# 阿里云百炼 DashScope（推荐 ✅ 400张免费额度）
# 获取: https://bailian.console.aliyun.com → 模型广场 → AI试衣Plus
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 图片对外可访问的基础 URL
IMAGE_BASE_URL=https://your-domain.pythonanywhere.com

# FASHN AI（付费）
FASHN_API_KEY=fa-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OOTDiffusion（自部署/Colab）
OOTD_API_URL=http://localhost:7860

# CORS 允许的前端地址
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
