      "source": [
        "# 🆓 Free AI Virtual Try-On\n",
        "### OOTDiffusion on Google Colab (Free T4 GPU)\n",
        "---\n",
        "**使用步骤:**\n",
        "1. 运行所有代码块 (Ctrl+F9)\n",
        "2. 最后一个 cell 会输出公共 API 地址\n",
        "3. 把地址填入后端的 OOTD_API_URL"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# 1. Install\n",
        "!pip install -q torch torchvision diffusers transformers accelerate gradio\n",
        "!pip install -q pyngrok Pillow opencv-python-headless\n",
        "!pip install -q huggingface_hub controlnet_aux"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# 2. Clone OOTDiffusion\n",
        "!git clone -q https://github.com/levihsu/OOTDiffusion.git /content/OOTDiffusion\n",
        "%cd /content/OOTDiffusion\n",
        "!pip install -q -r requirements.txt 2>/dev/null\n",
        "print('✅ Repo ready')"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# 3. Download models\n",
        "from huggingface_hub import hf_hub_download\n",
        "import os\n",
        "\n",
        "os.makedirs('/content/OOTDiffusion/checkpoints/ootd', exist_ok=True)\n",
        "\n",
        "# Download OOTDiffusion checkpoint (only ~6GB)\n",
        "print('Downloading OOTDiffusion model (~6GB)...')\n",
        "!huggingface-cli download levihsu/OOTDiffusion --local-dir /content/OOTDiffusion/checkpoints/ootd --local-dir-use-symlinks False 2>/dev/null\n",
        "print('✅ Model ready')"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# 4. Launch API Server\n",
        "import subprocess, time, sys\n",
        "from pyngrok import ngrok\n",
        "\n",
        "# Set your ngrok token (get free: https://dashboard.ngrok.com/get-started/setup)\n",
        "NGROK_TOKEN = \"YOUR_NGROK_AUTHTOKEN\"\n",
        "\n",
        "# Start Gradio in background\n",
        "!python /content/OOTDiffusion/app.py --server_port 7860 &\n",
        "time.sleep(10)\n",
        "\n",
        "# Expose via ngrok\n",
        "ngrok.set_auth_token(NGROK_TOKEN)\n",
        "url = ngrok.connect(7860).public_url\n",
        "print(f\"\\n{'='*50}\")\n",
        "print(f\"🚀 API URL: {url}\")\n",
        "print(f\"Gradio endpoint: {url}/api/predict\")\n",
        "print(f\"{'='*50}\\n\")\n",
        "print(\"Copy the URL above to OOTD_API_URL in your backend .env\")"
      ],
      "execution_count": null,
      "outputs": []
    }
  ]
}